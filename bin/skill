#
# Outputs $pid on each line
#
grep_name() {
  local name=$1

  pgrep $name
  #| while read line; do
  #  lsof -p $line
  #done
}

#
# grep_port <regex>
#
# Outputs $port $pid for each line
#
grep_port() {
  local port=$1

  netstat -anv | grep 'LISTEN' | tr -s ' ' | cut -d ' ' -f 4,9 | grep "\.$port" | cut -d '.' -f 2
}

grep_name $QUERY
#| while read line; do
